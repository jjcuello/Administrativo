# ===== Supabase base (ya existente en app) =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===== Agente IA =====
# Modo: gemini | local | hybrid
AI_AGENT_PROVIDER_MODE=hybrid

# Gemini (recomendado para calidad inicial)
GEMINI_API_KEY=
AI_AGENT_GEMINI_MODEL=gemini-2.5-flash

# Proveedor local (opcional / futuro)
# Si usas el adaptador local de scripts, apunta a:
# http://localhost:5055/generate
AI_AGENT_LOCAL_URL=

# Timeout general (ms)
AI_AGENT_TIMEOUT_MS=15000

# Requerida para que el agente consulte datos reales en backend
# NO exponer en frontend
SUPABASE_SERVICE_ROLE_KEY=

# ===== Opcional: adaptador local con Ollama =====
AI_LOCAL_PROVIDER_PORT=5055
AI_LOCAL_PROVIDER_USE_OLLAMA=true
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
AI_LOCAL_PROVIDER_TIMEOUT_MS=20000
